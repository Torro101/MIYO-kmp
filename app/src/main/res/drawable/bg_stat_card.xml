<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ MIYO UI/UX Redesign - Stat info card background
  ~ Surface container with subtle border + 12dp corners
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/miyo_corner_m" />
            <solid android:color="?attr/colorSurfaceContainer" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/miyo_corner_m" />
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="@dimen/miyo_card_border"
                android:color="@color/miyo_card_stroke" />
        </shape>
    </item>
</layer-list>
