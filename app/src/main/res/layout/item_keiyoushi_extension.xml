<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="?attr/selectableItemBackground"
	android:gravity="center_vertical"
	android:orientation="horizontal"
	android:paddingHorizontal="16dp"
	android:paddingVertical="12dp">

	<!-- Icon / extension type indicator -->
	<ImageView
		android:id="@+id/imageViewIcon"
		android:layout_width="40dp"
		android:layout_height="40dp"
		android:layout_marginEnd="12dp"
		android:contentDescription="@string/extension_type_keiyoushi"
		android:src="@drawable/ic_services"
		app:tint="?android:attr/textColorSecondary"
		/>

	<!-- Text content -->
	<LinearLayout
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_weight="1"
		android:orientation="vertical">

		<!-- Title row: name + NSFW badge -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_vertical"
			android:orientation="horizontal">

			<TextView
				android:id="@+id/textViewName"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:ellipsize="end"
				android:maxLines="1"
				android:textAppearance="?attr/textAppearanceTitleMedium"
				tools:text="MangaDex" />

			<TextView
				android:id="@+id/textViewNsfw"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="6dp"
				android:background="@drawable/bg_nsfw_badge"
				android:paddingHorizontal="4dp"
				android:paddingVertical="1dp"
				android:text="@string/keiyoushi_nsfw"
				android:textColor="?attr/colorOnError"
				android:textSize="10sp"
				android:visibility="gone"
				tools:visibility="visible" />

		</LinearLayout>

		<!-- Subtitle row: lang + version + sources -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="2dp"
			android:orientation="horizontal">

			<TextView
				android:id="@+id/textViewLang"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:background="@drawable/bg_lang_badge"
				android:paddingHorizontal="6dp"
				android:paddingVertical="2dp"
				android:textAppearance="?attr/textAppearanceLabelSmall"
				android:textColor="?attr/colorPrimary"
				tools:text="ALL" />

			<TextView
				android:id="@+id/textViewVersion"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:textAppearance="?attr/textAppearanceBodySmall"
				android:textColor="?android:attr/textColorSecondary"
				tools:text="1.4.50" />

			<TextView
				android:id="@+id/textViewSources"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:textAppearance="?attr/textAppearanceBodySmall"
				android:textColor="?android:attr/textColorSecondary"
				tools:text="3 sources" />

		</LinearLayout>

	</LinearLayout>

	<!-- Installed indicator -->
	<ImageView
		android:id="@+id/imageViewInstalled"
		android:layout_width="20dp"
		android:layout_height="20dp"
		android:layout_marginEnd="8dp"
		android:contentDescription="@string/keiyoushi_installed"
		android:src="@drawable/ic_check"
		app:tint="?attr/colorPrimary"
		android:visibility="gone"
		tools:ignore="UseAppTint"
		tools:visibility="visible" />

	<!-- Action button -->
	<com.google.android.material.button.MaterialButton
		android:id="@+id/buttonAction"
		style="@style/Widget.Material3.Button.TonalButton"
		android:layout_width="wrap_content"
		android:layout_height="36dp"
		android:layout_marginStart="4dp"
		android:minWidth="80dp"
		android:text="@string/keiyoushi_install"
		android:textSize="12sp" />

</LinearLayout>
