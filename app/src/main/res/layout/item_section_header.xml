<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ MIYO UI/UX Redesign - Section header row
  ~ Reusable header for sections like Description, Genres, Related, etc.
  ~
  ~ Layout: [icon] [UPPERCASE TITLE]  ... [ACTION BUTTON]
  ~ Used by DetailsActivity/Fragment new sections.
-->
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="@dimen/miyo_section_header_height"
        android:background="@drawable/bg_section_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/miyo_space_s"
        android:layout_marginVertical="@dimen/miyo_space_s"
        android:layout_marginHorizontal="@dimen/miyo_space_s">

    <ImageView
            android:id="@+id/imageView_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="@dimen/miyo_space_s"
            android:contentDescription="@null"
            android:src="@drawable/ic_metadata"
            android:tint="?attr/colorPrimary"
            tools:ignore="UseAppTint" />

    <TextView
            android:id="@+id/textView_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.Miyo.SectionHeader"
            android:textColor="?attr/colorOnSurface"
            tools:text="DESCRIPTION" />

    <FrameLayout
            android:id="@+id/container_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

</LinearLayout>
