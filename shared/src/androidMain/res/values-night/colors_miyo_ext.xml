        <color name="miyo_tile_bg_tertiary">#24F3C156</color>
        <color name="miyo_tile_bg_neutral">#24C0C8CC</color>

        <!-- FAB shadow -->
        <color name="miyo_fab_shadow">#595DDFEE</color>

