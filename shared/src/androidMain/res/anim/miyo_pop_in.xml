<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ MIYO UI/UX Redesign - Pop-in animation (for chips, badges, indicators)
  ~ Subtle scale + fade; quick and tactile.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
     android:duration="180"
     android:interpolator="@android:interpolator/fast_out_slow_in">
    <alpha
        android:fromAlpha="0"
        android:toAlpha="1" />
    <scale
        android:fromXScale="0.7"
        android:fromYScale="0.7"
        android:pivotX="50%"
        android:pivotY="50%"
        android:toXScale="1"
        android:toYScale="1" />
</set>
