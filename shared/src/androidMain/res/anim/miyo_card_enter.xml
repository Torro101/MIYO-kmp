<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ MIYO UI/UX Redesign - Card entrance animation (fade + subtle slide up)
  ~ Used by RecyclerView item animator for staggered entrance.
  ~ Duration: 240ms with fast_out_slow_in interpolator (M3 standard).
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
     android:duration="240"
     android:interpolator="@android:interpolator/fast_out_slow_in">
    <alpha
        android:fromAlpha="0"
        android:toAlpha="1" />
    <translate
        android:fromYDelta="@dimen/miyo_stagger_translation"
        android:toYDelta="0" />
</set>
